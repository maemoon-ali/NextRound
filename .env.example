# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git.

# LiveData Technologies API (https://gotlivedata.io)
LIVEDATA_API_KEY=ldtkey_your_key_here
LIVEDATA_ORG_ID=o_603b3359
LIVEDATA_API_URL=https://gotlivedata.io/api/people/v1

# Ollama (runs locally — install from https://ollama.com)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
