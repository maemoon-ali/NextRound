# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git.

# LiveData Technologies API (https://gotlivedata.io)
LIVEDATA_API_KEY=your_livedata_api_key_here
LIVEDATA_ORG_ID=your_org_id_here
LIVEDATA_API_HOST=https://gotlivedata.io/api/people/v1

# Ollama (runs locally — install from https://ollama.com)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
